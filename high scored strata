import numpy as np
import pandas as pd


def filter_current_month_or_later(df, score_date_col="score_date", current_period="2026-04"):
    df = df.copy()
    df[score_date_col] = pd.to_datetime(df[score_date_col])

    period_start = pd.Period(current_period, freq="M").start_time

    return df[df[score_date_col] >= period_start].copy()


def get_high_score_population(df, cutoff_by_pct, pct_cutoff=99.0, score_col="global_max_score"):
    cutoff = cutoff_by_pct[pct_cutoff]
    high_df = df[df[score_col] >= cutoff].copy()
    return high_df, cutoff


def create_buckets_from_percentile_df(df, cutoff_by_pct, score_col="global_max_score"):
    p99   = cutoff_by_pct[99.0]
    p995  = cutoff_by_pct[99.5]
    p998  = cutoff_by_pct[99.8]
    p999  = cutoff_by_pct[99.9]
    p9997 = cutoff_by_pct[99.97]

    df = df.copy()

    df["bucket"] = pd.cut(
        df[score_col],
        bins=[p99, p995, p998, p999, p9997, np.inf],
        labels=["P99-99.5", "P99.5-99.8", "P99.8-99.9", "P99.9-99.97", "P99.97-100"],
        include_lowest=True
    )

    return df


def exclude_previously_reviewed(df, prev_selected_df):
    if prev_selected_df is None or prev_selected_df.empty:
        return df.copy()

    reviewed_keys = prev_selected_df[["PTY_ID", "PARTY_KEY"]].drop_duplicates()

    merged = df.merge(
        reviewed_keys,
        on=["PTY_ID", "PARTY_KEY"],
        how="left",
        indicator=True
    )

    return merged[merged["_merge"] == "left_only"].drop(columns=["_merge"])


def allocate_targets(df, total_target, min_per_type=2):
    summary = (
        df.dropna(subset=["bucket", "acct_type"])
          .groupby(["bucket", "acct_type"], observed=True)
          .size()
          .reset_index(name="available_accounts")
    )

    if summary.empty:
        raise ValueError("No rows available after grouping by bucket and acct_type.")

    bucket_totals = (
        summary.groupby("bucket", observed=True)["available_accounts"]
        .sum()
        .reset_index(name="bucket_total")
    )

    summary = summary.merge(bucket_totals, on="bucket", how="left")

    n_buckets = summary["bucket"].nunique()
    if n_buckets == 0:
        raise ValueError("No populated buckets available.")

    per_bucket_target = total_target / n_buckets

    allocations = []
    for _, row in summary.iterrows():
        prop = row["available_accounts"] / row["bucket_total"]
        target = int(round(prop * per_bucket_target))
        target = max(target, min_per_type)
        target = min(target, row["available_accounts"])

        allocations.append({
            "bucket": row["bucket"],
            "acct_type": row["acct_type"],
            "target": target,
            "available_accounts": row["available_accounts"]
        })

    return pd.DataFrame(allocations)


def prepare_ranked_candidates(df, score_col="global_max_score", score_date_col="score_date"):
    df = df.copy()
    df[score_date_col] = pd.to_datetime(df[score_date_col])

    # Global ranking rule within each customer:
    # 1) highest score
    # 2) latest score date
    # 3) smallest PARTY_KEY as stable deterministic tie-breaker
    df = df.sort_values(
        ["PTY_ID", score_col, score_date_col, "PARTY_KEY"],
        ascending=[True, False, False, True]
    ).copy()

    df["global_pty_rank"] = df.groupby("PTY_ID").cumcount() + 1
    return df


def stratified_account_sampling_global_cap(
    df,
    allocations,
    prev_selected_df=None,
    max_accounts_per_customer=1,
    seed=42,
    score_col="global_max_score",
    score_date_col="score_date"
):
    df = df.copy()

    # 1) remove previously reviewed accounts
    df = exclude_previously_reviewed(df, prev_selected_df)

    if df.empty:
        return pd.DataFrame()

    # 2) create a GLOBAL per-customer ranking so top-N is fixed across the entire sample
    df = prepare_ranked_candidates(df, score_col=score_col, score_date_col=score_date_col)

    # 3) pre-limit each customer to their global top-N accounts
    df = df[df["global_pty_rank"] <= max_accounts_per_customer].copy()

    if df.empty:
        return pd.DataFrame()

    sampled_parts = []
    already_selected_pairs = set()
    selected_count_by_pty = {}

    # Shuffle order of rows within each slice, but only AFTER top-N has already been fixed globally
    for _, row in allocations.iterrows():
        bucket = row["bucket"]
        acct_type = row["acct_type"]
        target = int(row["target"])

        subset = df[
            (df["bucket"] == bucket) &
            (df["acct_type"] == acct_type)
        ].copy()

        if subset.empty or target <= 0:
            continue

        subset = subset.sample(frac=1, random_state=seed).copy()

        chosen_rows = []

        for _, cand in subset.iterrows():
            pair = (cand["PTY_ID"], cand["PARTY_KEY"])
            pty = cand["PTY_ID"]

            if pair in already_selected_pairs:
                continue

            if selected_count_by_pty.get(pty, 0) >= max_accounts_per_customer:
                continue

            chosen_rows.append(cand)
            already_selected_pairs.add(pair)
            selected_count_by_pty[pty] = selected_count_by_pty.get(pty, 0) + 1

            if len(chosen_rows) >= target:
                break

        if chosen_rows:
            sampled_parts.append(pd.DataFrame(chosen_rows))

    sampled_df = pd.concat(sampled_parts, ignore_index=True) if sampled_parts else pd.DataFrame()

    # 4) final overlap safety check against prior reviewed ledger
    if prev_selected_df is not None and not prev_selected_df.empty and not sampled_df.empty:
        overlap = sampled_df.merge(
            prev_selected_df[["PTY_ID", "PARTY_KEY"]].drop_duplicates(),
            on=["PTY_ID", "PARTY_KEY"],
            how="inner"
        )
        if not overlap.empty:
            raise AssertionError(f"Overlap detected with previous selections: {len(overlap)} rows")

    # 5) final global cap safety check
    if not sampled_df.empty:
        counts = sampled_df.groupby("PTY_ID")["PARTY_KEY"].nunique()
        bad = counts[counts > max_accounts_per_customer]
        if not bad.empty:
            raise AssertionError("Global max_accounts_per_customer cap violated.")

    return sampled_df


def build_summary(sampled_df):
    if sampled_df.empty:
        return pd.DataFrame()

    return (
        sampled_df.groupby(["bucket", "acct_type"], observed=True, as_index=False)
        .agg(
            sampled_accounts=("PARTY_KEY", "count"),
            unique_customers=("PTY_ID", "nunique"),
            avg_score=("global_max_score", "mean")
        )
    )


def build_population_summary(df):
    if df.empty:
        return pd.DataFrame()

    return (
        df.groupby(["bucket", "acct_type"], observed=True, as_index=False)
        .agg(
            available_accounts=("PARTY_KEY", "count"),
            unique_customers=("PTY_ID", "nunique"),
            avg_score=("global_max_score", "mean")
        )
    )

