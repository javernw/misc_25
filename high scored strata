    merged = df.merge(
        prev_selected_df[["PTY_ID", "PARTY_KEY"]],
        on=["PTY_ID", "PARTY_KEY"],
        how="left",
        indicator=True
    )

    return merged[merged["_merge"] == "left_only"].drop(columns=["_merge"])

def create_percentile_buckets(df, score_col="global_max_score"):
    percentiles = df[score_col].rank(pct=True) * 100

    bins = [99.0, 99.5, 99.8, 99.9, 99.97, 100.0]
    labels = ["P99-99.5", "P99.5-99.8", "P99.8-99.9", "P99.9-99.97", "P99.97-100"]

    df = df.copy()
    df["score_pct"] = percentiles
    df["bucket"] = pd.cut(percentiles, bins=bins, labels=labels, include_lowest=True)

    return df


def allocate_targets(df, total_target, min_per_type=2):
    summary = (
        df.groupby(["bucket", "acct_type"])
        .size()
        .reset_index(name="count")
    )

    bucket_totals = summary.groupby("bucket")["count"].sum()

    allocations = []

    for bucket in bucket_totals.index:
        bucket_df = summary[summary["bucket"] == bucket]
        total_bucket = bucket_totals[bucket]

        for _, row in bucket_df.iterrows():
            prop = row["count"] / total_bucket
            target = int(round(prop * total_target / len(bucket_totals)))

            # enforce minimum floor
            target = max(target, min_per_type)

            allocations.append({
                "bucket": bucket,
                "acct_type": row["acct_type"],
                "target": target
            })

    return pd.DataFrame(allocations)


