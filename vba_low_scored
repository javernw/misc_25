Private Sub FormatSarTextInColumnG(ws As Worksheet, startRow As Long, rowCount As Long)

    Dim r As Long
    Dim cell As Range
    Dim txt As String
    Dim sepPos As Long
    
    For r = startRow To startRow + rowCount - 1
        
        Set cell = ws.Cells(r, "G")
        txt = CStr(cell.Value)
        
        If Len(txt) > 0 Then
            
            ' Reset formatting
            cell.Font.ColorIndex = xlAutomatic
            
            ' Find separator "|"
            sepPos = InStr(1, txt, "|")
            
            If sepPos > 0 Then
                
                ' LEFT SIDE -> Non-SAR (Green)
                If sepPos > 1 Then
                    cell.Characters(1, sepPos - 1).Font.Color = RGB(0, 128, 0)
                End If
                
                ' RIGHT SIDE -> SAR (Red)
                If sepPos < Len(txt) Then
                    cell.Characters(sepPos + 1, Len(txt) - sepPos).Font.Color = RGB(255, 0, 0)
                End If
                
            Else
                ' Fallback if no separator found
                If InStr(1, txt, "Non", vbTextCompare) > 0 Then
                    cell.Font.Color = RGB(0, 128, 0)
                ElseIf InStr(1, txt, "Sar", vbTextCompare) > 0 Then
                    cell.Font.Color = RGB(255, 0, 0)
                End If
            End If
            
        End If
        
    Next r

End Sub


