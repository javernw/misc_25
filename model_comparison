def plot_account_timeseries(acct_id, df_ts):
    temp = df_ts[df_ts["acct_id"] == acct_id].sort_values("score_date")
    
    plt.figure(figsize=(10,5))
    plt.plot(temp["score_date"], temp["iter1_score"], marker="o", label="Iter 1")
    plt.plot(temp["score_date"], temp["iter2_score"], marker="o", label="Iter 2")
    plt.title(f"Score Time Series: {acct_id}")
