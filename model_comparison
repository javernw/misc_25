def summarize_ts(group):
    out = {
        "n_dates": group[DATE_COL].nunique(),
        "iter1_mean": group["iter1_score"].mean(),
        "iter2_mean": group["iter2_score"].mean(),
        "mean_diff": group["iter2_score"].mean() - group["iter1_score"].mean(),
        "iter1_std": group["iter1_score"].std(),
        "iter2_std": group["iter2_score"].std()
    }

    valid = group[["iter1_score", "iter2_score"]].dropna()
    out["paired_dates"] = len(valid)

    if len(valid) >= 2:
        out["corr"] = valid["iter1_score"].corr(valid["iter2_score"])
    else:
        out["corr"] = np.nan

    return pd.Series(out)

