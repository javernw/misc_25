11. Time series drift metrics per account

This gives you summary stats for accounts that returned.

def summarize_ts(group):
    out = {}
    out["n_dates"] = group["score_date"].nunique()
    out["iter1_mean"] = group["iter1_score"].mean()
    out["iter2_mean"] = group["iter2_score"].mean()
    out["mean_diff"] = out["iter2_mean"] - out["iter1_mean"]
    out["iter1_std"] = group["iter1_score"].std()
    out["iter2_std"] = group["iter2_score"].std()
    
    valid = group[["iter1_score", "iter2_score"]].dropna()
    if len(valid) >= 2:
        out["corr"] = valid["iter1_score"].corr(valid["iter2_score"])
    else:
        out["corr"] = np.nan
    
    return pd.Series(out)

acct_ts_summary = (
    ts_compare.groupby("acct_id")
    .apply(summarize_ts)
    .reset_index()
)

acct_ts_summary.head()

Interpretation:
	•	mean_diff > 0: account tends to score higher in iter2
	•	corr high: shape of score movement over time is similar
	•	corr low: iter2 is seeing risk differently

