14. Detection window alignment

If you have:
	•	min_suspicious_date
	•	max_suspicious_date

Attach those to the max-score tables.

# Suppose sar_window has acct_id, min_suspicious_date, max_suspicious_date
sar_window["min_suspicious_date"] = pd.to_datetime(sar_window["min_suspicious_date"])
sar_window["max_suspicious_date"] = pd.to_datetime(sar_window["max_suspicious_date"])

window_compare = common_max.merge(sar_window, on="acct_id", how="left")

def classify_window(score_date, min_dt, max_dt):
    if pd.isna(score_date) or pd.isna(min_dt) or pd.isna(max_dt):
        return np.nan
    elif score_date < min_dt:
        return "before"
    elif score_date > max_dt:
        return "after"
    else:
        return "inside"

window_compare["iter1_window_position"] = window_compare.apply(
    lambda x: classify_window(x["iter1_max_score_date"], x["min_suspicious_date"], x["max_suspicious_date"]),
    axis=1
)

window_compare["iter2_window_position"] = window_compare.apply(
    lambda x: classify_window(x["iter2_max_score_date"], x["min_suspicious_date"], x["max_suspicious_date"]),
    axis=1
)

window_transition = pd.crosstab(
    window_compare["iter1_window_position"],
    window_compare["iter2_window_position"],
    margins=True
)

print(window_transition)


