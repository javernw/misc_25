def threshold_simulation(max1_df, max2_df, p=0.90):
    thr1 = max1_df["iter1_max_score"].quantile(p)
    thr2 = max2_df["iter2_max_score"].quantile(p)

    alert1 = set(max1_df.loc[max1_df["iter1_max_score"] >= thr1, ID_COL].dropna().unique())
    alert2 = set(max2_df.loc[max2_df["iter2_max_score"] >= thr2, ID_COL].dropna().unique())

    summary = pd.DataFrame({
        "metric": [
            f"iter1_alerts_p{int(p*100)}",
            f"iter2_alerts_p{int(p*100)}",
            "common_alerts",
            "lost_alerts",
            "new_alerts"
        ],
        "value": [
            len(alert1),
            len(alert2),
            len(alert1 & alert2),
            len(alert1 - alert2),
            len(alert2 - alert1)
        ]
    })

    return summary, thr1, thr2, alert1, alert2

print_section("15. THRESHOLD IMPACT SIMULATION")

for p in [0.90, 0.95, 0.99]:
    summary, thr1, thr2, _, _ = threshold_simulation(max1, max2, p=p)
    print(f"\nPercentile threshold: {p:.0%}")
    print(f"Iter 1 threshold = {thr1:.6f}")
    print(f"Iter 2 threshold = {thr2:.6f}")
