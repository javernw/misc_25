# ============================================================
# Iteration 1 vs Iteration 2 Model Comparison Notebook
# Pandas template for score drift, overlap, timing, and stability
# ============================================================

import pandas as pd
import numpy as np
import matplotlib.pyplot as plt

pd.set_option("display.max_columns", 200)
pd.set_option("display.width", 200)

# ------------------------------------------------------------
# 0. USER INPUTS / CONFIG
# ------------------------------------------------------------

# Replace these with your actual dataframes
# df_iter1 = ...
# df_iter2 = ...
# sar_window = ...  # optional

ID_COL = "acct_id"
DATE_COL = "score_date"
SCORE_COL = "xgb_score"

# Optional columns if present
SAR_TYPE_COL = "sar_type"          # e.g. Auto SAR / Manual / Not SAR
SEGMENT_COL = "segment"            # e.g. Consumer / Business
SAR_WINDOW_MIN_COL = "min_suspicious_date"
SAR_WINDOW_MAX_COL = "max_suspicious_date"

AUTO_SAR_VALUE = "Auto SAR"

# Thresholds for movement classification
SCORE_DIFF_MATERIAL = 0.10

# Risk band cutoffs based on percentile rank
LOW_BAND_CUTOFF = 0.50
HIGH_BAND_CUTOFF = 0.90

# ------------------------------------------------------------
# 1. STANDARDIZE INPUTS
# ------------------------------------------------------------

def standardize_input(df, iteration_name):
    df = df.copy()
    df[DATE_COL] = pd.to_datetime(df[DATE_COL])
    df["iteration"] = iteration_name
    return df

df_iter1 = standardize_input(df_iter1, "iter1")
df_iter2 = standardize_input(df_iter2, "iter2")

print("Iter 1 shape:", df_iter1.shape)
print("Iter 2 shape:", df_iter2.shape)


# ------------------------------------------------------------
# 2. BASIC HELPERS
# ------------------------------------------------------------

def safe_divide(a, b):
    return np.where(b != 0, a / b, np.nan)

def classify_score_movement(diff, materiality=SCORE_DIFF_MATERIAL):
    if pd.isna(diff):
        return np.nan
    if diff > materiality:
        return "increased materially"
    elif diff < -materiality:
        return "decreased materially"
    return "roughly stable"

def risk_band(p):
    if pd.isna(p):
        return np.nan
    if p < LOW_BAND_CUTOFF:
        return "low"
    elif p < HIGH_BAND_CUTOFF:
        return "medium"
    return "high"

def classify_date_shift(days):
    if pd.isna(days):
        return np.nan
    if days < 0:
        return "earlier in iter2"
    elif days > 0:
        return "later in iter2"
    return "same date"

def classify_window_position(score_date, min_dt, max_dt):
    if pd.isna(score_date) or pd.isna(min_dt) or pd.isna(max_dt):
        return np.nan
    if score_date < min_dt:
        return "before"
    elif score_date > max_dt:
        return "after"
    return "inside"

def print_section(title):
    print("\n" + "=" * 80)
    print(title)
    print("=" * 80)

def summarize_numeric(series, name):
    out = series.describe(percentiles=[0.5, 0.75, 0.9, 0.95, 0.99]).to_frame(name)
    return out


# ------------------------------------------------------------
# 3. POPULATION OVERLAP
# ------------------------------------------------------------

def get_population_overlap(df1, df2, id_col=ID_COL):
    acct1 = set(df1[id_col].dropna().unique())
    acct2 = set(df2[id_col].dropna().unique())

    common = acct1 & acct2
    dropped = acct1 - acct2
    new = acct2 - acct1

    summary = pd.DataFrame({
        "metric": [
            "iter1_accounts",
            "iter2_accounts",
            "common_accounts",
            "dropped_from_iter1",
            "new_in_iter2"
        ],
        "value": [
            len(acct1),
            len(acct2),
            len(common),
            len(dropped),
            len(new)
        ]
    })

    summary["pct_of_iter1"] = np.nan
    summary["pct_of_iter2"] = np.nan

    if len(acct1) > 0:
        summary.loc[summary["metric"].isin(["common_accounts", "dropped_from_iter1"]), "pct_of_iter1"] = (
            summary.loc[summary["metric"].isin(["common_accounts", "dropped_from_iter1"]), "value"] / len(acct1)
        )

    if len(acct2) > 0:
        summary.loc[summary["metric"].isin(["common_accounts", "new_in_iter2"]), "pct_of_iter2"] = (
            summary.loc[summary["metric"].isin(["common_accounts", "new_in_iter2"]), "value"] / len(acct2)
        )

    return summary, common, dropped, new

pop_summary, common_accts, dropped_accts, new_accts = get_population_overlap(df_iter1, df_iter2)

print_section("3. POPULATION OVERLAP")
print(pop_summary)

df_common_accts = pd.DataFrame({ID_COL: sorted(common_accts)})
df_dropped_accts = pd.DataFrame({ID_COL: sorted(dropped_accts)})
df_new_accts = pd.DataFrame({ID_COL: sorted(new_accts)})


# ------------------------------------------------------------
# 4. MAX SCORE PER ACCOUNT
# ------------------------------------------------------------

def get_max_score_per_account(df, iteration_prefix, id_col=ID_COL, date_col=DATE_COL, score_col=SCORE_COL):
    temp = df[[id_col, date_col, score_col]].dropna(subset=[id_col, score_col]).copy()
    idx = temp.groupby(id_col)[score_col].idxmax()
    out = temp.loc[idx].copy()

    out = out.rename(columns={
        date_col: f"{iteration_prefix}_max_score_date",
        score_col: f"{iteration_prefix}_max_score"
    })

    return out[[id_col, f"{iteration_prefix}_max_score_date", f"{iteration_prefix}_max_score"]]

max1 = get_max_score_per_account(df_iter1, "iter1")
max2 = get_max_score_per_account(df_iter2, "iter2")

max_compare = max1.merge(max2, on=ID_COL, how="outer")

max_compare["acct_status"] = np.select(
    [
        max_compare["iter1_max_score"].notna() & max_compare["iter2_max_score"].notna(),
        max_compare["iter1_max_score"].notna() & max_compare["iter2_max_score"].isna(),
        max_compare["iter1_max_score"].isna() & max_compare["iter2_max_score"].notna()
    ],
    ["common", "dropped", "new"],
    default="unknown"
)

print_section("4. MAX SCORE PER ACCOUNT")
print(max_compare["acct_status"].value_counts(dropna=False))


# ------------------------------------------------------------
# 5. SCORE DRIFT FOR COMMON ACCOUNTS
# ------------------------------------------------------------

common_max = max_compare[max_compare["acct_status"] == "common"].copy()

common_max["score_diff"] = common_max["iter2_max_score"] - common_max["iter1_max_score"]
common_max["score_diff_abs"] = common_max["score_diff"].abs()
common_max["score_diff_pct"] = safe_divide(
    common_max["iter2_max_score"] - common_max["iter1_max_score"],
    common_max["iter1_max_score"]
)
common_max["score_movement"] = common_max["score_diff"].apply(classify_score_movement)

print_section("5. SCORE DRIFT FOR COMMON ACCOUNTS")
print(summarize_numeric(common_max["score_diff"], "score_diff"))
print("\nMovement buckets:")
print(common_max["score_movement"].value_counts(dropna=False))


# ------------------------------------------------------------
# 6. MAX SCORE DATE SHIFT
# ------------------------------------------------------------

common_max["date_shift_days"] = (
    common_max["iter2_max_score_date"] - common_max["iter1_max_score_date"]
).dt.days

common_max["date_shift_bucket"] = common_max["date_shift_days"].apply(classify_date_shift)

print_section("6. MAX SCORE DATE SHIFT")
print(summarize_numeric(common_max["date_shift_days"], "date_shift_days"))
print("\nDate shift buckets:")
print(common_max["date_shift_bucket"].value_counts(dropna=False))


# ------------------------------------------------------------
# 7. PERCENTILE / RISK BAND STABILITY
# ------------------------------------------------------------

